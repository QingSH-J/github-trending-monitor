spring.application.name=github-trending-monitor
server.port=${PORT:8080}

# Database
spring.datasource.url=${DATABASE_URL:jdbc:mysql://localhost:3306/github_trending?connectionTimeZone=UTC&allowPublicKeyRetrieval=true}
spring.datasource.username=${DATABASE_USERNAME:your_db_username}
spring.datasource.password=${DATABASE_PASSWORD:your_db_password}
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# JPA
spring.jpa.hibernate.ddl-auto=${JPA_DDL_AUTO:validate}
spring.jpa.show-sql=${JPA_SHOW_SQL:false}
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect

# JWT
app.jwt.secret=${JWT_SECRET:your_jwt_secret_at_least_256_bits_long}
app.jwt.expiration-ms=${JWT_EXPIRATION_MS:604800000}
app.oauth2.redirect-url=${FRONTEND_OAUTH_REDIRECT_URL:http://localhost:5173/oauth/callback}

# OAuth2
spring.security.oauth2.client.registration.github.client-id=${GITHUB_CLIENT_ID:your_github_client_id}
spring.security.oauth2.client.registration.github.client-secret=${GITHUB_CLIENT_SECRET:your_github_client_secret}
spring.security.oauth2.client.registration.github.scope=user:email,read:user

# Redis
spring.data.redis.host=${REDIS_HOST:localhost}
spring.data.redis.port=${REDIS_PORT:6379}
spring.data.redis.password=${REDIS_PASSWORD:}

# CORS
app.cors.allowed-origins=${CORS_ALLOWED_ORIGINS:http://localhost:5173,http://127.0.0.1:5173}

# AI provider
app.deepseek.api-key=${DEEPSEEK_API_KEY:your_deepseek_api_key}

# Email provider
app.mail.provider=resend
app.mail.resend-api-key=${RESEND_API_KEY:your_resend_api_key}
app.mail.from=${MAIL_FROM:digest@qingshiyuu.com}
app.mail.from-name=${MAIL_FROM_NAME:Repo Radar}
